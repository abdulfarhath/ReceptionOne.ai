# Copy this file to api/.env and fill in real values. Never commit api/.env.

# Port the API listens on (the web dev server proxies /api here).
PORT=3000

# Secret used to sign staff JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
# Session JWT/cookie lifetime in seconds (default 3600 = 1 hour).
JWT_EXPIRES_SECONDS=3600
# Name of the httpOnly auth cookie (default "session").
AUTH_COOKIE_NAME=session
# DEV ONLY: set to "true" to skip staff login locally. Leave unset in prod/CI.
AUTH_BYPASS=

# Reminders: set to "true" to run the reminder cron inside the API process, or
# run the standalone worker with `npm run reminders`. REMINDER_CRON overrides the
# schedule (default every 2 minutes).
ENABLE_REMINDERS=
REMINDER_CRON=

# Initial admin account, created/reset by `npm run db:seed:admin`.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NAME=Administrator

# --- Neon Postgres ---------------------------------------------------------
# DATABASE_URL: the POOLED connection string (runtime queries via PgBouncer).
#   Neon dashboard -> your project -> Connection string -> "Pooled connection".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"

# DIRECT_URL: the NON-POOLED connection string (Prisma migrations).
#   Neon dashboard -> same project -> uncheck "Pooled connection".
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- WhatsApp via Twilio (free sandbox) ------------------------------------
# If these three are set, the app uses Twilio; otherwise it falls back to the
# Mock channel (use `npm run chat` to simulate a patient in the terminal).
#   Twilio Console -> Account Info (SID, Auth Token)
#   Messaging -> Try it out -> WhatsApp sandbox (the sandbox "from" number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Public HTTPS origin Twilio calls for the webhook (e.g. your ngrok URL), used
# to validate the X-Twilio-Signature. Example: https://your-id.ngrok-free.app
PUBLIC_URL=

# --- AI (only when the NLU/LLM layer is built) -----------------------------
ANTHROPIC_API_KEY=
