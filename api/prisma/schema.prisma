// Prisma schema for receptionone.ai.
// Status is stored as a String and mapped to the AppointmentStatus union at the
// PrismaRepository boundary. AppointmentEvent is append-only (insert + read only).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon pooled (pgbouncer)
  directUrl = env("DIRECT_URL") // Neon non-pooled, for migrations
}

model Staff {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String // ADMIN | RECEPTIONIST
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  phone     String   @unique // E.164
  state     String // ConversationState step name
  context   Json // in-progress booking context (action, doctorId, offered options…)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Doctor {
  id                  String         @id @default(cuid())
  name                String
  phone               String?
  department          String
  slotDurationMinutes Int // legacy (slot model removed); kept for back-compat
  avgConsultMinutes   Int            @default(15) // drives queue wait estimates
  availability        Availability[]
  appointments        Appointment[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

// Reinterpreted as a SESSION window: which weekdays the queue is open and the
// open/close clock times. startMinutes is the session start used for arrival
// estimates. No discrete slots are generated from this.
model Availability {
  id           String @id @default(cuid())
  doctorId     String
  doctor       Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0=Sun .. 6=Sat
  startMinutes Int // session open, minutes from midnight (UTC)
  endMinutes   Int // session close, minutes from midnight (UTC)

  @@index([doctorId, dayOfWeek])
}

model Patient {
  id           String        @id @default(cuid())
  phone        String        @unique // E.164
  name         String
  language     String        @default("en")
  consentAt    DateTime?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// A live queue entry (one queue per doctor per queueDate). The slot model is
// gone: there is no start/end time, only a token and lifecycle timestamps.
model Appointment {
  id        String  @id @default(cuid())
  doctorId  String
  doctor    Doctor  @relation(fields: [doctorId], references: [id])
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  queueDate  DateTime // the clinic day this entry belongs to (UTC midnight)
  token      Int // per doctor per queueDate, starting at 1
  isWalkIn   Boolean  @default(false)
  isPriority Boolean  @default(false)
  onHold     Boolean  @default(false) // absent when called; board skips it

  // "Come at my own time": preferred target (UTC). Null = immediate token (come
  // now). Still a token, not a reserved slot — enters the live queue around this
  // time and gets an honest window.
  targetTime DateTime?

  arrivedAt DateTime? // checked in
  startedAt DateTime? // consult began
  doneAt    DateTime? // consult ended

  lastNotifiedMaxMinutes Int? // last max-wait told to the patient (slip re-notify)

  start DateTime? // legacy (slot model removed)
  end   DateTime? // legacy

  status        String // WAITING | ARRIVED | IN_PROGRESS | DONE | NO_SHOW | CANCELLED
  events        AppointmentEvent[]
  notifications Notification[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([doctorId, queueDate, token])
  @@index([doctorId, queueDate])
}

model AppointmentEvent {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  type          String // BOOKED | RESCHEDULED | CANCELLED | COMPLETED
  metadata      Json?
  at            DateTime    @default(now())

  @@index([appointmentId])
}

// A one-to-many broadcast: a single message sent to all consented patients
// (announcements, camps, drives, promos…). Sent immediately or scheduled; a cron
// dispatches due ones. category/priority/status are Strings mapped to unions at
// the repository boundary, like Appointment.status.
model Broadcast {
  id             String    @id @default(cuid())
  title          String
  body           String
  category       String // BroadcastCategory
  priority       String // LOW | NORMAL | HIGH | URGENT
  status         String // SCHEDULED | SENT
  scheduledAt    DateTime? // null = send immediately
  sentAt         DateTime? // set when actually dispatched
  recipientCount Int       @default(0) // patients reached
  createdById    String
  createdByName  String // denormalised sender name for history
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([createdAt])
}

// Outbound notification ledger. The unique (appointmentId, kind) makes reminders
// idempotent: the job claims a row before sending, so it sends at most once and
// is safe to re-run. Confirmations are sent inline and not recorded here.
model Notification {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  kind          String // REMINDER_24H | REMINDER_2H
  sentAt        DateTime    @default(now())

  @@unique([appointmentId, kind])
  @@index([appointmentId])
}
